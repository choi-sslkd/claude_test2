FROM node:20-slim

WORKDIR /app

# Install OpenSSL for Prisma
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl && rm -rf /var/lib/apt/lists/*

# Rule engine package - 먼저 복사 + 설치
COPY packages/rule-engine/ packages/rule-engine/
RUN cd packages/rule-engine && npm install

# API deps
COPY apps/api/package.json apps/api/package-lock.json apps/api/
RUN cd apps/api && npm install --ignore-scripts

# rule-engine을 직접 복사 (심볼릭 링크 대신)
RUN rm -rf apps/api/node_modules/@prompt-guard/rule-engine && \
    mkdir -p apps/api/node_modules/@prompt-guard && \
    cp -r packages/rule-engine apps/api/node_modules/@prompt-guard/rule-engine

# API source + prisma
COPY apps/api/ apps/api/

# rule-engine 다시 복사 (COPY가 node_modules를 덮어쓸 수 있으므로)
RUN mkdir -p apps/api/node_modules/@prompt-guard && \
    cp -r packages/rule-engine apps/api/node_modules/@prompt-guard/rule-engine

# Generate Prisma client
RUN cd apps/api && npx prisma generate --schema prisma/schema.prisma

# Build NestJS
RUN cd apps/api && npm run build

EXPOSE 3000

WORKDIR /app/apps/api

CMD ["node", "dist/src/main"]
