FROM node:20-slim

WORKDIR /app

# Install OpenSSL for Prisma
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl && rm -rf /var/lib/apt/lists/*

# Root deps
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts 2>/dev/null || npm install

# Rule engine package
COPY packages/rule-engine/package.json packages/rule-engine/package-lock.json packages/rule-engine/
RUN cd packages/rule-engine && npm ci 2>/dev/null || npm install

COPY packages/rule-engine/ packages/rule-engine/

# API deps
COPY apps/api/package.json apps/api/package-lock.json apps/api/
RUN cd apps/api && npm ci 2>/dev/null || npm install

# API source + prisma
COPY apps/api/ apps/api/

# Generate Prisma client
RUN cd apps/api && npx prisma generate --schema prisma/schema.prisma

# Build NestJS
RUN cd apps/api && npm run build

EXPOSE 3000

WORKDIR /app/apps/api

CMD ["node", "dist/main"]
